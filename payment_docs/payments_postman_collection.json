									"mode": "raw",
									"raw": "{\n    \"amount\": 0\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/payments/set-fee/:applicationId",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"payments",
										"set-fee",
										":applicationId"
									],
									"variable": [
										{
											"key": "applicationId",
											"value": "12"
										}
									]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
