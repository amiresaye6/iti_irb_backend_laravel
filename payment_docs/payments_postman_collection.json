				{
					"name": "Initiate Checkout (Paymob)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.status && jsonData.client_secret) {",
									"    if (pm.environment.name) {",
									"        pm.environment.set(\"clientSecret\", jsonData.client_secret);",
									"    }",
									"    pm.collectionVariables.set(\"clientSecret\", jsonData.client_secret);",
									"    console.log(\"Client secret saved automatically!\");",
									"}"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/payments/checkout/:applicationId",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"payments",
								"checkout",
								":applicationId"
							],
							"variable": [
								{
									"key": "applicationId",
									"value": "12",
									"description": "ID of the application in awaiting_payment stage to start checkout for"
								}
							]
						},
						"description": "Requests checkout credentials from the Paymob Intention API for a specific application.\n\n### Returns:\n- `checkout_url`: Redirection link to redirect the student to the unified Paymob checkout page.\n- `client_secret`: Unique client secret from Paymob.\n- `payment_methods`: Configured payment modes (e.g. `card`, `wallet`).\n\n*Automatically saves the generated `client_secret` to Postman variables to be used in the verification endpoint.*"
					},
					"response": [
						{
							"name": "Success Response",
							"originalRequest": {
								"method": "POST",
								"header": [
									{
										"key": "Accept",
										"value": "application/json"
									}
								],
								"url": {
