				{
					"name": "Set Payment Fee",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"amount\": 1500.00\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/payments/set-fee/:applicationId",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"payments",
								"set-fee",
								":applicationId"
							],
							"variable": [
								{
									"key": "applicationId",
									"value": "12",
									"description": "ID of the application in approved_by_reviewer stage to set the fee for"
								}
							]
						},
						"description": "Set the required fee for an application after its final reviewer approval.\n\n### Business Rules:\n1. If `amount` is set to `0`:\n   - Skips the payment stage entirely and advances application directly to `approved`.\n   - Generates a pseudo-payment record marked as `paid` with transaction ID `ZERO_FEES`.\n2. If `amount` is `> 0`:\n   - Creates a pending payment record.\n   - Changes application status to `awaiting_payment` so the student can checkout.\n\n### Requirements:\n- Must be logged in as `admin` or `manager`.\n- The application must be in the `approved_by_reviewer` stage."
					},
					"response": [
						{
							"name": "Success (Fee > 0)",
							"originalRequest": {
								"method": "POST",
								"header": [
									{
										"key": "Content-Type",
										"value": "application/json"
									},
									{
										"key": "Accept",
										"value": "application/json"
									}
								],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"amount\": 1500.00\n}"
								},
								"url": {
									"raw": "{{baseUrl}}/payments/set-fee/:applicationId",
									"host": [
										"{{baseUrl}}"
									],
									"path": [
										"payments",
										"set-fee",
										":applicationId"
									],
									"variable": [
										{
											"key": "applicationId",
											"value": "12"
										}
									]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
								{
									"key": "Content-Type",
									"value": "application/json"
								}
							],
							"cookie": [],
							"body": "{\n    \"status\": true,\n    \"message\": \"Fee set to 1500 EGP. Application status changed to awaiting_payment.\",\n    \"payment\": {\n        \"application_id\": 12,\n        \"amount\": 1500,\n        \"status\": \"pending\",\n        \"updated_at\": \"2026-05-30T15:02:00.000000Z\",\n        \"created_at\": \"2026-05-30T15:02:00.000000Z\",\n        \"id\": 3\n    }\n}"
						},
