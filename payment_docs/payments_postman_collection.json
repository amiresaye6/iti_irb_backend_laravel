									"value": "application/json"
								}
							],
							"cookie": [],
							"body": "{\n    \"status\": true,\n    \"message\": \"Application fee set to 0. Application stage advanced to approved automatically.\",\n    \"payment\": {\n        \"application_id\": 12,\n        \"amount\": 0,\n        \"status\": \"paid\",\n        \"transaction_id\": \"ZERO_FEES\",\n        \"paid_at\": \"2026-05-30T15:02:30.000000Z\",\n        \"updated_at\": \"2026-05-30T15:02:30.000000Z\",\n        \"created_at\": \"2026-05-30T15:02:30.000000Z\",\n        \"id\": 4\n    }\n}"
